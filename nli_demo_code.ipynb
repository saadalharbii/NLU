import argparse
import json
import os
import random
import re
from collections import Counter
from dataclasses import dataclass
from typing import Dict, List, Optional, Sequence

import pandas as pd
import torch
import torch.nn as nn
from sklearn.metrics import accuracy_score, f1_score
from torch.nn.utils.rnn import pack_padded_sequence, pad_packed_sequence
from torch.utils.data import DataLoader, Dataset


def set_seed(seed: int = 42) -> None:
    random.seed(seed)
    torch.manual_seed(seed)
    if torch.cuda.is_available():
        torch.cuda.manual_seed_all(seed)
    torch.set_num_threads(max(1, min(4, torch.get_num_threads())))


TOKEN_PATTERN = re.compile(r"\w+|[^\w\s]", re.UNICODE)


def simple_tokenize(text: str) -> List[str]:
    if pd.isna(text):
        return []
    return TOKEN_PATTERN.findall(str(text).lower())


class Vocab:
    PAD = "<pad>"
    UNK = "<unk>"

    def __init__(self, stoi: Dict[str, int]):
        self.stoi = stoi
        self.itos = [None] * len(stoi)
        for tok, idx in stoi.items():
            self.itos[idx] = tok

    @classmethod
    def build(
        cls,
        texts: Sequence[Sequence[str]],
        min_freq: int = 2,
        max_size: Optional[int] = 30000,
    ) -> "Vocab":
        counter = Counter()
        for toks in texts:
            counter.update(toks)

        stoi = {cls.PAD: 0, cls.UNK: 1}
        items = sorted(counter.items(), key=lambda x: (-x[1], x[0]))
        for token, freq in items:
            if freq < min_freq:
                continue
            if max_size is not None and len(stoi) >= max_size:
                break
            stoi[token] = len(stoi)
        return cls(stoi)

    def encode(self, tokens: Sequence[str], max_len: Optional[int] = None) -> List[int]:
        if max_len is not None:
            tokens = tokens[:max_len]
        return [self.stoi.get(tok, self.stoi[self.UNK]) for tok in tokens]

    @property
    def pad_id(self) -> int:
        return self.stoi[self.PAD]

    def to_dict(self) -> Dict[str, int]:
        return dict(self.stoi)

    @classmethod
    def from_dict(cls, stoi: Dict[str, int]) -> "Vocab":
        return cls(stoi)


class NLIDataset(Dataset):
    def __init__(
        self,
        df: pd.DataFrame,
        vocab: Vocab,
        label_to_id: Optional[Dict[str, int]] = None,
        max_len: int = 128,
        has_labels: bool = True,
    ):
        self.df = df.copy()
        self.vocab = vocab
        self.max_len = max_len
        self.has_labels = has_labels

        self.premise_tokens = [simple_tokenize(t) for t in self.df["premise"].tolist()]
        self.hypothesis_tokens = [simple_tokenize(t) for t in self.df["hypothesis"].tolist()]

        self.premise_ids = [self.vocab.encode(toks, max_len) for toks in self.premise_tokens]
        self.hypothesis_ids = [self.vocab.encode(toks, max_len) for toks in self.hypothesis_tokens]

        self.label_to_id = label_to_id
        if has_labels:
            if label_to_id is None:
                labels = sorted(self.df["label"].astype(str).unique().tolist())
                self.label_to_id = {lab: i for i, lab in enumerate(labels)}
            self.labels = [self.label_to_id[str(x)] for x in self.df["label"].tolist()]
        else:
            self.labels = None

    def __len__(self) -> int:
        return len(self.df)

    def __getitem__(self, idx: int):
        item = {
            "premise_ids": self.premise_ids[idx],
            "hypothesis_ids": self.hypothesis_ids[idx],
        }
        if self.has_labels:
            item["label"] = self.labels[idx]
        return item


def make_collate_fn(pad_id: int):
    def collate_fn(batch: List[Dict]):
        premise_lengths = [max(1, len(x["premise_ids"])) for x in batch]
        hypothesis_lengths = [max(1, len(x["hypothesis_ids"])) for x in batch]
        max_p = max(premise_lengths)
        max_h = max(hypothesis_lengths)

        premise_tensor = torch.full((len(batch), max_p), pad_id, dtype=torch.long)
        hypothesis_tensor = torch.full((len(batch), max_h), pad_id, dtype=torch.long)

        for i, x in enumerate(batch):
            p_ids = x["premise_ids"][:max_p]
            h_ids = x["hypothesis_ids"][:max_h]
            if p_ids:
                premise_tensor[i, : len(p_ids)] = torch.tensor(p_ids, dtype=torch.long)
            if h_ids:
                hypothesis_tensor[i, : len(h_ids)] = torch.tensor(h_ids, dtype=torch.long)

        batch_out = {
            "premise_ids": premise_tensor,
            "premise_lengths": torch.tensor(premise_lengths, dtype=torch.long),
            "hypothesis_ids": hypothesis_tensor,
            "hypothesis_lengths": torch.tensor(hypothesis_lengths, dtype=torch.long),
        }
        if "label" in batch[0]:
            batch_out["labels"] = torch.tensor([x["label"] for x in batch], dtype=torch.long)
        return batch_out

    return collate_fn


class SharedBiLSTMEncoder(nn.Module):
    def __init__(
        self,
        vocab_size: int,
        embed_dim: int,
        hidden_dim: int,
        pad_idx: int,
        num_layers: int = 1,
        dropout: float = 0.3,
    ):
        super().__init__()
        self.embedding = nn.Embedding(vocab_size, embed_dim, padding_idx=pad_idx)
        self.embedding_dropout = nn.Dropout(dropout)
        self.lstm = nn.LSTM(
            input_size=embed_dim,
            hidden_size=hidden_dim,
            num_layers=num_layers,
            batch_first=True,
            dropout=dropout if num_layers > 1 else 0.0,
            bidirectional=True,
        )
        self.output_dim = hidden_dim * 4

    def forward(self, input_ids: torch.Tensor, lengths: torch.Tensor) -> torch.Tensor:
        embedded = self.embedding_dropout(self.embedding(input_ids))
        packed = pack_padded_sequence(
            embedded,
            lengths.cpu(),
            batch_first=True,
            enforce_sorted=False,
        )
        packed_out, _ = self.lstm(packed)
        out, _ = pad_packed_sequence(packed_out, batch_first=True)

        time_steps = out.size(1)
        mask = (torch.arange(time_steps, device=lengths.device)[None, :] < lengths[:, None]).unsqueeze(-1)

        masked_out = out * mask
        denom = lengths.clamp_min(1).unsqueeze(1).to(out.dtype)
        mean_pool = masked_out.sum(dim=1) / denom

        neg_inf = torch.tensor(-1e9, device=out.device, dtype=out.dtype)
        max_pool = out.masked_fill(~mask, neg_inf).max(dim=1).values
        return torch.cat([mean_pool, max_pool], dim=1)


class NLIBiLSTMClassifier(nn.Module):
    def __init__(
        self,
        vocab_size: int,
        embed_dim: int,
        hidden_dim: int,
        pad_idx: int,
        num_classes: int,
        num_layers: int = 1,
        dropout: float = 0.3,
        mlp_dim: int = 256,
    ):
        super().__init__()
        self.encoder = SharedBiLSTMEncoder(
            vocab_size=vocab_size,
            embed_dim=embed_dim,
            hidden_dim=hidden_dim,
            pad_idx=pad_idx,
            num_layers=num_layers,
            dropout=dropout,
        )
        sent_dim = self.encoder.output_dim
        pair_dim = sent_dim * 4
        self.classifier = nn.Sequential(
            nn.Linear(pair_dim, mlp_dim),
            nn.ReLU(),
            nn.Dropout(dropout),
            nn.Linear(mlp_dim, num_classes),
        )

    def forward(self, premise_ids, premise_lengths, hypothesis_ids, hypothesis_lengths):
        u = self.encoder(premise_ids, premise_lengths)
        v = self.encoder(hypothesis_ids, hypothesis_lengths)
        feats = torch.cat([u, v, torch.abs(u - v), u * v], dim=1)
        return self.classifier(feats)


@dataclass
class TrainConfig:
    train_csv: str
    dev_csv: str
    output_dir: str = "runs/nli_bilstm"
    batch_size: int = 64
    epochs: int = 15
    lr: float = 1e-3
    weight_decay: float = 1e-4
    embed_dim: int = 200
    hidden_dim: int = 128
    mlp_dim: int = 256
    num_layers: int = 1
    dropout: float = 0.3
    max_len: int = 128
    min_freq: int = 2
    max_vocab_size: int = 30000
    patience: int = 3
    seed: int = 42


def load_csv_checked(path: str, require_labels: bool = True) -> pd.DataFrame:
    df = pd.read_csv(path)
    required = ["premise", "hypothesis"]
    if require_labels:
        required.append("label")
    missing = [c for c in required if c not in df.columns]
    if missing:
        raise ValueError(f"{path} is missing required columns: {missing}")
    return df


def build_vocab_from_train(train_df: pd.DataFrame, min_freq: int, max_vocab_size: int) -> Vocab:
    all_tokens = []
    for text in train_df["premise"].tolist():
        all_tokens.append(simple_tokenize(text))
    for text in train_df["hypothesis"].tolist():
        all_tokens.append(simple_tokenize(text))
    return Vocab.build(all_tokens, min_freq=min_freq, max_size=max_vocab_size)


def make_loaders(train_df, dev_df, vocab, label_to_id, cfg):
    train_ds = NLIDataset(train_df, vocab, label_to_id=label_to_id, max_len=cfg.max_len, has_labels=True)
    dev_ds = NLIDataset(dev_df, vocab, label_to_id=label_to_id, max_len=cfg.max_len, has_labels=True)
    collate_fn = make_collate_fn(vocab.pad_id)
    train_loader = DataLoader(train_ds, batch_size=cfg.batch_size, shuffle=True, collate_fn=collate_fn)
    dev_loader = DataLoader(dev_ds, batch_size=cfg.batch_size, shuffle=False, collate_fn=collate_fn)
    return train_loader, dev_loader


def compute_loss_and_preds(model, batch, criterion, device):
    premise_ids = batch["premise_ids"].to(device)
    premise_lengths = batch["premise_lengths"].to(device)
    hypothesis_ids = batch["hypothesis_ids"].to(device)
    hypothesis_lengths = batch["hypothesis_lengths"].to(device)
    labels = batch.get("labels")
    if labels is not None:
        labels = labels.to(device)

    logits = model(
        premise_ids=premise_ids,
        premise_lengths=premise_lengths,
        hypothesis_ids=hypothesis_ids,
        hypothesis_lengths=hypothesis_lengths,
    )
    loss = criterion(logits, labels) if labels is not None else None
    preds = torch.argmax(logits, dim=1)
    return loss, preds


def train_one_epoch(model, loader, optimizer, criterion, device):
    model.train()
    total_loss = 0.0
    all_preds, all_labels = [], []

    for batch in loader:
        optimizer.zero_grad()
        loss, preds = compute_loss_and_preds(model, batch, criterion, device)
        loss.backward()
        nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
        optimizer.step()

        total_loss += loss.item() * batch["labels"].size(0)
        all_preds.extend(preds.detach().cpu().tolist())
        all_labels.extend(batch["labels"].tolist())

    avg_loss = total_loss / len(loader.dataset)
    macro_f1 = f1_score(all_labels, all_preds, average="macro")
    acc = accuracy_score(all_labels, all_preds)
    return {"loss": avg_loss, "macro_f1": macro_f1, "accuracy": acc}


@torch.no_grad()
def evaluate(model, loader, criterion, device):
    model.eval()
    total_loss = 0.0
    all_preds, all_labels = [], []

    for batch in loader:
        loss, preds = compute_loss_and_preds(model, batch, criterion, device)
        total_loss += loss.item() * batch["labels"].size(0)
        all_preds.extend(preds.cpu().tolist())
        all_labels.extend(batch["labels"].tolist())

    avg_loss = total_loss / len(loader.dataset)
    macro_f1 = f1_score(all_labels, all_preds, average="macro")
    acc = accuracy_score(all_labels, all_preds)
    return {"loss": avg_loss, "macro_f1": macro_f1, "accuracy": acc}


def save_checkpoint(model, path, vocab, label_to_id, cfg):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    torch.save(
        {
            "model_state_dict": model.state_dict(),
            "vocab_stoi": vocab.to_dict(),
            "label_to_id": label_to_id,
            "config": cfg.__dict__,
        },
        path,
    )


def load_model_from_checkpoint(checkpoint_path: str, device: torch.device):
    payload = torch.load(checkpoint_path, map_location=device)
    cfg = TrainConfig(**payload["config"])
    vocab = Vocab.from_dict(payload["vocab_stoi"])
    label_to_id = payload["label_to_id"]

    model = NLIBiLSTMClassifier(
        vocab_size=len(vocab.itos),
        embed_dim=cfg.embed_dim,
        hidden_dim=cfg.hidden_dim,
        pad_idx=vocab.pad_id,
        num_classes=len(label_to_id),
        num_layers=cfg.num_layers,
        dropout=cfg.dropout,
        mlp_dim=cfg.mlp_dim,
    )
    model.load_state_dict(payload["model_state_dict"])
    model.to(device)
    model.eval()
    return model, vocab, label_to_id, cfg


def train_model(cfg: TrainConfig) -> str:
    set_seed(cfg.seed)
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

    train_df = load_csv_checked(cfg.train_csv, require_labels=True)
    dev_df = load_csv_checked(cfg.dev_csv, require_labels=True)
    vocab = build_vocab_from_train(train_df, cfg.min_freq, cfg.max_vocab_size)
    labels = sorted(train_df["label"].astype(str).unique().tolist())
    label_to_id = {lab: i for i, lab in enumerate(labels)}

    train_loader, dev_loader = make_loaders(train_df, dev_df, vocab, label_to_id, cfg)

    model = NLIBiLSTMClassifier(
        vocab_size=len(vocab.itos),
        embed_dim=cfg.embed_dim,
        hidden_dim=cfg.hidden_dim,
        pad_idx=vocab.pad_id,
        num_classes=len(label_to_id),
        num_layers=cfg.num_layers,
        dropout=cfg.dropout,
        mlp_dim=cfg.mlp_dim,
    ).to(device)

    criterion = nn.CrossEntropyLoss()
    optimizer = torch.optim.AdamW(model.parameters(), lr=cfg.lr, weight_decay=cfg.weight_decay)

    best_f1 = -1.0
    best_path = os.path.join(cfg.output_dir, "best_model.pt")
    history = []
    bad_epochs = 0

    for epoch in range(1, cfg.epochs + 1):
        train_metrics = train_one_epoch(model, train_loader, optimizer, criterion, device)
        dev_metrics = evaluate(model, dev_loader, criterion, device)
        row = {
            "epoch": epoch,
            "train_loss": train_metrics["loss"],
            "train_macro_f1": train_metrics["macro_f1"],
            "train_accuracy": train_metrics["accuracy"],
            "dev_loss": dev_metrics["loss"],
            "dev_macro_f1": dev_metrics["macro_f1"],
            "dev_accuracy": dev_metrics["accuracy"],
        }
        history.append(row)
        print(json.dumps(row))

        if dev_metrics["macro_f1"] > best_f1:
            best_f1 = dev_metrics["macro_f1"]
            save_checkpoint(model, best_path, vocab, label_to_id, cfg)
            bad_epochs = 0
        else:
            bad_epochs += 1

        if bad_epochs >= cfg.patience:
            print(f"Early stopping at epoch {epoch}. Best dev macro-F1 = {best_f1:.4f}")
            break

    os.makedirs(cfg.output_dir, exist_ok=True)
    pd.DataFrame(history).to_csv(os.path.join(cfg.output_dir, "training_history.csv"), index=False)
    return best_path


@torch.no_grad()
def predict_dataframe(model, vocab, id_to_label, df, batch_size, max_len, device):
    ds = NLIDataset(df, vocab, label_to_id=None, max_len=max_len, has_labels=False)
    loader = DataLoader(ds, batch_size=batch_size, shuffle=False, collate_fn=make_collate_fn(vocab.pad_id))
    predictions = []
    model.eval()

    for batch in loader:
        premise_ids = batch["premise_ids"].to(device)
        premise_lengths = batch["premise_lengths"].to(device)
        hypothesis_ids = batch["hypothesis_ids"].to(device)
        hypothesis_lengths = batch["hypothesis_lengths"].to(device)

        logits = model(
            premise_ids=premise_ids,
            premise_lengths=premise_lengths,
            hypothesis_ids=hypothesis_ids,
            hypothesis_lengths=hypothesis_lengths,
        )
        pred_ids = torch.argmax(logits, dim=1).cpu().tolist()
        predictions.extend([id_to_label[i] for i in pred_ids])
    return predictions


def run_inference(checkpoint_path: str, input_csv: str, output_csv: str, batch_size: int = 64):
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    model, vocab, label_to_id, cfg = load_model_from_checkpoint(checkpoint_path, device)
    id_to_label = {i: lab for lab, i in label_to_id.items()}

    df = load_csv_checked(input_csv, require_labels=False)
    preds = predict_dataframe(model, vocab, id_to_label, df, batch_size=batch_size, max_len=cfg.max_len, device=device)
    pd.DataFrame({"label": preds}).to_csv(output_csv, index=False)
    print(f"Saved predictions to {output_csv}")


def evaluate_checkpoint(checkpoint_path: str, dev_csv: str, batch_size: int = 64):
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    model, vocab, label_to_id, cfg = load_model_from_checkpoint(checkpoint_path, device)
    dev_df = load_csv_checked(dev_csv, require_labels=True)
    ds = NLIDataset(dev_df, vocab, label_to_id=label_to_id, max_len=cfg.max_len, has_labels=True)
    loader = DataLoader(ds, batch_size=batch_size, shuffle=False, collate_fn=make_collate_fn(vocab.pad_id))
    metrics = evaluate(model, loader, nn.CrossEntropyLoss(), device)
    print(json.dumps(metrics, indent=2))


def parse_args():
    parser = argparse.ArgumentParser(description="Non-transformer BiLSTM solution for NLI")
    subparsers = parser.add_subparsers(dest="mode", required=True)

    train_parser = subparsers.add_parser("train")
    train_parser.add_argument("--train_csv", type=str, required=True)
    train_parser.add_argument("--dev_csv", type=str, required=True)
    train_parser.add_argument("--output_dir", type=str, default="runs/nli_bilstm")
    train_parser.add_argument("--batch_size", type=int, default=64)
    train_parser.add_argument("--epochs", type=int, default=15)
    train_parser.add_argument("--lr", type=float, default=1e-3)
    train_parser.add_argument("--weight_decay", type=float, default=1e-4)
    train_parser.add_argument("--embed_dim", type=int, default=200)
    train_parser.add_argument("--hidden_dim", type=int, default=128)
    train_parser.add_argument("--mlp_dim", type=int, default=256)
    train_parser.add_argument("--num_layers", type=int, default=1)
    train_parser.add_argument("--dropout", type=float, default=0.3)
    train_parser.add_argument("--max_len", type=int, default=128)
    train_parser.add_argument("--min_freq", type=int, default=2)
    train_parser.add_argument("--max_vocab_size", type=int, default=30000)
    train_parser.add_argument("--patience", type=int, default=3)
    train_parser.add_argument("--seed", type=int, default=42)

    eval_parser = subparsers.add_parser("eval")
    eval_parser.add_argument("--checkpoint", type=str, required=True)
    eval_parser.add_argument("--dev_csv", type=str, required=True)
    eval_parser.add_argument("--batch_size", type=int, default=64)

    predict_parser = subparsers.add_parser("predict")
    predict_parser.add_argument("--checkpoint", type=str, required=True)
    predict_parser.add_argument("--input_csv", type=str, required=True)
    predict_parser.add_argument("--output_csv", type=str, required=True)
    predict_parser.add_argument("--batch_size", type=int, default=64)

    return parser.parse_args()


def main():
    args = parse_args()
    if args.mode == "train":
        cfg = TrainConfig(
            train_csv=args.train_csv,
            dev_csv=args.dev_csv,
            output_dir=args.output_dir,
            batch_size=args.batch_size,
            epochs=args.epochs,
            lr=args.lr,
            weight_decay=args.weight_decay,
            embed_dim=args.embed_dim,
            hidden_dim=args.hidden_dim,
            mlp_dim=args.mlp_dim,
            num_layers=args.num_layers,
            dropout=args.dropout,
            max_len=args.max_len,
            min_freq=args.min_freq,
            max_vocab_size=args.max_vocab_size,
            patience=args.patience,
            seed=args.seed,
        )
        best_path = train_model(cfg)
        print(f"Best checkpoint saved to: {best_path}")
    elif args.mode == "eval":
        evaluate_checkpoint(args.checkpoint, args.dev_csv, args.batch_size)
    elif args.mode == "predict":
        run_inference(args.checkpoint, args.input_csv, args.output_csv, args.batch_size)


if __name__ == "__main__":
    main()
